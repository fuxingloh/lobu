#!/bin/sh

echo "🔍 Running pre-commit checks..."

# Run format check
echo "📝 Checking code formatting with Biome..."
bun run format:check
if [ $? -ne 0 ]; then
  echo "❌ Formatting issues found. Run 'bun run format' to fix them."
  exit 1
fi

# Run lint check
echo "🔎 Running linter with Biome..."
bun run lint
if [ $? -ne 0 ]; then
  echo "❌ Linting issues found. Fix them before committing."
  exit 1
fi

# Run TypeScript type check
echo "📘 Running TypeScript type check..."
bun run typecheck
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Fix them before committing."
  exit 1
fi

echo "✅ All pre-commit checks passed!"