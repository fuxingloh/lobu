---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { SkillsSection } from "../components/SkillsSection";
import { Footer } from "../components/Footer";
import { Nav } from "../components/Nav";
---

<BaseLayout title="Skills as SaaS - Ship SaaS as an OpenClaw skill" description="Package your domain expertise as skills. Users install them to turn a general-purpose agent into a specialized one.">
  <div class="min-h-screen grid-lines" style={{ backgroundColor: "var(--color-page-bg)" }}>
    <Nav />
    <main class="relative z-[1]">
      <SkillsSection />
    </main>
    <Footer />
  </div>
</BaseLayout>
