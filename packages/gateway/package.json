{
  "name": "@peerbot/gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Slack gateway service that routes messages to Kubernetes worker Jobs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "start": "cd ../core && bun run build && cd ../gateway && bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kubernetes/client-node": "0.21.0",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@peerbot/core": "workspace:*",
    "@sentry/node": "^10.19.0",
    "@slack/bolt": "^4.5.0",
    "@slack/types": "^2.17.0",
    "@slack/web-api": "^7.11.0",
    "@types/multer": "^2.0.0",
    "@types/node-fetch": "^2.6.13",
    "bullmq": "^5.31.5",
    "commander": "^14.0.1",
    "dockerode": "^4.0.7",
    "dotenv": "^17.2.1",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "marked": "^12.0.0",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.29",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/marked": "^6.0.0",
    "typescript": "^5.8.3"
  }
}
