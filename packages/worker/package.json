{
  "name": "@peerbot/worker",
  "version": "0.1.0",
  "description": "Peerbot worker runtime - run in your own Docker image or use our base image",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "peerbot-worker": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "peerbot",
    "worker",
    "slack",
    "ai",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/buremba/peerbot.git",
    "directory": "packages/worker"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.25",
    "@peerbot/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.8.3"
  }
}
