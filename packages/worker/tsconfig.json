{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*", "mcp/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/__tests__/**"]
}
