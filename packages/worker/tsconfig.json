{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/**/*",
    "mcp/**/*",
    "../../modules/**/*",
    "../shared/src/**/*"
  ],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/__tests__/**"]
}
