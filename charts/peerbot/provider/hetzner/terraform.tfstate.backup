    {
      "module": "module.kube-hetzner.module.agents[\"1-0-egress\"]",
      "mode": "managed",
      "type": "hcloud_server",
      "name": "server",
      "provider": "provider[\"registry.terraform.io/hetznercloud/hcloud\"]",
      "instances": [
